# ═══════════════════════════════════════════════════════════════
# Annex27 — Server Security Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Force HTTPS ─────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Clean URLs (hide .html extension) ───────────────────────
# 1. Redirect /page.html → /page (external 301 for SEO)
RewriteCond %{THE_REQUEST} \s/+([^?\s]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301,NE]

# 2. Internally rewrite /page → /page.html (when the .html file exists)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# ─── Security Headers ────────────────────────────────────────
<IfModule mod_headers.c>
  # Force HTTPS for 2 years + preload eligible (HSTS)
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Prevent clickjacking — DENY is stricter than SAMEORIGIN
  Header always set X-Frame-Options "DENY"

  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Legacy XSS filter (older browsers only, modern use CSP)
  Header always set X-XSS-Protection "1; mode=block"

  # Strict referrer policy — only send origin on cross-origin
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy — disable all sensitive browser features
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

  # Cross-Origin policies
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # Content Security Policy - strict allowlist
  # Note: 'unsafe-inline' for style needed for SVG and inline styling of dashboard
  # For script we keep unsafe-inline because all our JS is inline — can be tightened later with nonces
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://tvqhxhoohzdzekcfzjuv.supabase.co https://api.mollie.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; frame-ancestors 'none'; form-action 'self' https://*.mollie.com https://formsubmit.co; base-uri 'self'; object-src 'none'; upgrade-insecure-requests;"

  # Hide server fingerprinting
  Header unset Server
  Header unset X-Powered-By

  # Cache control for HTML — prevent caching sensitive pages
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# ─── Disable directory listing ───────────────────────────────
Options -Indexes

# ─── Block access to sensitive files ─────────────────────────
<FilesMatch "^\.(env|git|htaccess|annex27_ftp)|\.(sql|md|sh|py|yml|yaml|json|log|bak)$">
  Require all denied
</FilesMatch>

# ─── Block access to hidden folders (except .well-known for security.txt etc.) ──
RedirectMatch 404 /\.(?!well-known)\..*$
RedirectMatch 404 /\.(env|git|htaccess|annex27_ftp|vscode)(/|$)

# ─── Block access to beleidspakket folder (policy docs) ──────
# Policy documents should ONLY be served via Supabase Storage with signed URLs
<IfModule mod_rewrite.c>
  RewriteRule ^beleidspakket/ - [F,L]
  RewriteRule ^docs/.+\.(docx|pdf|xlsx)$ - [F,L]
</IfModule>

# ─── Cache static assets ─────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ─── Custom 404 page ─────────────────────────────────────────
ErrorDocument 404 /index.html

# ─── Prevent image hotlinking ────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?annex27\.(nl|com|eu)/.*$ [NC]
  RewriteCond %{HTTP_REFERER} !^https?://annex27\.nl/.*$ [NC]
  RewriteRule \.(jpg|jpeg|png|gif|svg|webp)$ - [F]
</IfModule>
